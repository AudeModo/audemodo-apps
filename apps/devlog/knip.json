{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["steiger.config.ts"]
    },
    "apps/devlog": {
      "entry": ["app/**/{page,layout,loading,error,not-found,route,template,default}.tsx"],
      "project": ["{app,src}/**/*.{ts,tsx}"],
      "ignore": ["src/**/*.mdx"]
    }
  },
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}

{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/devlog": {
      "entry": ["src/app/**/{page,layout,loading,error,not-found,route,template,default}.tsx"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["src/**/*.mdx"]
    }
  },
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
